# ─── Local development (Vite proxy — recommended) ───
# Keeps auth cookies on the same origin as the UI.
# VITE_API_URL=/api
# VITE_SOCKET_URL=

# ─── Production / direct backend URL ───
# Use when the built frontend is served separately from the API.
# VITE_API_URL=https://your-api.example.com/api
# VITE_SOCKET_URL=https://your-api.example.com
